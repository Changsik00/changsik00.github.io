---
const categories = [
  {
    label: 'Frontend',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    primary: true,
    skills: ['React', 'Next.js', 'Vue.js', 'TypeScript', 'TailwindCSS', 'Zustand', 'TanStack Query', 'GraphQL', 'Vite / Webpack', 'Storybook'],
  },
  {
    label: 'Backend',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    primary: true,
    skills: ['NestJS', 'FastAPI', 'Node.js', 'Express', 'MongoDB', 'PostgreSQL', 'TypeORM', 'REST API'],
  },
  {
    label: 'Mobile',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    primary: false,
    skills: ['Android Native', 'Kotlin', 'Java', 'JNI / C++', 'iOS (Swift)', 'Ionic / Cordova'],
  },
  {
    label: 'DevOps / Infra',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>`,
    primary: false,
    skills: ['Docker', 'GitHub Actions', 'Nginx', 'Linux', 'CI/CD'],
  },
  {
    label: 'Data Visualization',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    primary: false,
    skills: ['D3.js', 'ApexCharts', 'Chart.js'],
  },
  {
    label: 'AI / 관심 영역',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a5 5 0 1 0 5 5"/><path d="M12 12a5 5 0 1 0 5 5"/><path d="M2 12a5 5 0 1 0 5 5"/></svg>`,
    primary: false,
    accent: true,
    skills: ['RAG', 'AI Agent Workflow', 'Vibe Coding (SDD)', 'LangChain', 'Vector DB', 'Embedding Pipeline', 'LLM Application'],
  },
];
---

<section id="skills" style="padding: 5rem 1.5rem; max-width: 1100px; margin: 0 auto;">
  <h2 class="section-heading">Tech Stack</h2>

  <!-- Skill icons row (primary stack) -->
  <div style="margin-bottom: 3rem; text-align: center;">
    <img
      src="https://skillicons.dev/icons?i=ts,react,nextjs,vue,nodejs,nestjs,fastapi,python,kotlin,docker,postgres,mongodb,git&perline=13"
      alt="Primary tech stack icons"
      style="max-width: 100%; height: auto;"
      loading="lazy"
    />
  </div>

  <!-- Categorized skills -->
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem;">
    {categories.map(cat => (
      <div class="card" style={cat.accent ? 'border-color: rgba(124,58,237,0.4);' : ''}>
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
          <span style={`color: ${cat.accent ? 'var(--accent-light)' : cat.primary ? 'var(--text)' : 'var(--muted)'};`} set:html={cat.icon} />
          <h3 style={`font-size: 0.9rem; font-weight: 600; color: ${cat.accent ? 'var(--accent-light)' : 'var(--text)'};`}>{cat.label}</h3>
          {cat.primary && <span style="margin-left: auto; font-size: 0.68rem; padding: 0.1rem 0.5rem; border-radius: 9999px; background: rgba(124,58,237,0.15); color: var(--accent-light); border: 1px solid rgba(124,58,237,0.3);">주력</span>}
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
          {cat.skills.map(s => (
            <span class={`tag ${cat.accent ? 'tag-accent' : ''}`}>{s}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
