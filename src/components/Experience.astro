---

<section id="experience" style="padding: 5rem 1.5rem; background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div style="max-width: 1100px; margin: 0 auto;">
    <h2 class="section-heading">Experience</h2>

    <div style="position: relative; padding-left: 2rem;">
      <!-- Vertical line -->
      <div style="position: absolute; left: 0.5625rem; top: 0.5rem; bottom: 2rem; width: 1px; background: linear-gradient(to bottom, var(--border), transparent);"></div>

      {jobs.map((job, i) => (
        <div style={`position: relative; margin-bottom: ${i < jobs.length - 1 ? '3rem' : '0'};`}>
          <!-- Timeline dot -->
          <div style={`position: absolute; left: -2rem; top: 0.35rem; width: 0.875rem; height: 0.875rem; border-radius: 50%; background: ${job.color}; border: 2px solid var(--bg); box-shadow: 0 0 0 2px ${job.color}40;`}></div>

          <div class="card" style={`border-left: 2px solid ${job.color}30;`}>
            <div style="display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.75rem;">
              <div>
                <h3 style="font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem;">{job.company}</h3>
                <p style="font-size: 0.875rem; color: var(--muted);">{job.role}</p>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <p style={`font-size: 0.8rem; font-weight: 500; color: ${job.color}; font-family: 'JetBrains Mono', monospace;`}>{job.period}</p>
                <p style="font-size: 0.75rem; color: var(--muted);">{job.duration}</p>
              </div>
            </div>

            <ul style="margin-bottom: 1rem; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem;">
              {job.highlights.map(h => (
                <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.85rem; color: var(--muted); line-height: 1.5;">
                  <span style={`color: ${job.color}; margin-top: 0.2rem; flex-shrink: 0;`}>›</span>
                  {h}
                </li>
              ))}
            </ul>

            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
              {job.stack.map(s => (
                <span class="tag">{s}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
