---
const live = [
  {
    name: 'Signal.bz',
    url: 'https://www.signal.bz',
    description: '토이 프로젝트로 시작해 2022년 개발 완료 후 무중단으로 안정 운영 중. 현재는 서버 모니터링만 수행하는 상태로, 별도 유지보수 없이 자체적으로 잘 돌아가고 있습니다.',
    stack: ['React', 'NestJS', 'MongoDB', 'TailwindCSS'],
    status: 'stable',
  },
  {
    name: 'Teambinder.ai',
    url: 'https://www.teambinder.ai',
    description: 'AI 기반 키워드 모니터링 플랫폼. Agent Workflow와 RAG를 실험적으로 적용하며 개발 중인 프로젝트입니다.',
    stack: ['React', 'FastAPI', 'NestJS', 'MongoDB', 'AI Workflow'],
    status: 'live',
  },
];

const recent = [
  {
    name: 'rag-ingestion',
    url: 'https://github.com/Changsik00/rag-ingestion',
    description: 'RAG 시스템에서 사용할 지식 그래프 구축 및 임베딩 파이프라인 실험. Vibe Coding (SDD) 방식으로 개발.',
    stack: ['Python', 'RAG', 'Vector DB', 'Embedding'],
    label: 'RAG / SDD',
  },
  {
    name: 'harness-kit',
    url: 'https://github.com/Changsik00/harness-kit',
    description: 'AI Agent 워크플로우를 효율적으로 관리하기 위한 하네스 도구 모음.',
    stack: ['TypeScript', 'Node.js', 'AI Agent'],
    label: 'AI Tooling',
  },
  {
    name: 'node-settings',
    url: 'https://github.com/Changsik00/node-settings',
    description: 'Node.js 설정 관리 유틸리티. NPM 패키지로 배포하여 실제 사용 가능한 오픈소스 도구.',
    stack: ['TypeScript', 'Node.js', 'NPM'],
    label: 'NPM Package',
  },
  {
    name: 'gen-design',
    url: 'https://github.com/Changsik00/gen-design',
    description: 'DESIGN.md 기반 디자이너 협업 워크플로우 자동화 도구. 개발 중.',
    stack: ['TypeScript', 'Design System', 'Automation'],
    label: 'In Progress',
    wip: true,
  },
];
---

<section id="projects" style="padding: 5rem 1.5rem; background: var(--surface); border-top: 1px solid var(--border);">
  <div style="max-width: 1100px; margin: 0 auto;">
    <h2 class="section-heading">Projects</h2>

    <!-- Live services -->
    <h3 style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1.25rem;">운영 중인 서비스</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.25rem; margin-bottom: 3rem;">
      {live.map(p => (
        <a href={p.url} target="_blank" rel="noopener" class="card" style="text-decoration: none; display: block; cursor: pointer;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
            <h3 style="font-size: 1rem; font-weight: 700; color: var(--text);">{p.name}</h3>
            <div style="display: flex; align-items: center; gap: 0.4rem;">
              {p.status === 'stable'
                ? <>
                    <span style="width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #7aa2f7;"></span>
                    <span style="font-size: 0.72rem; color: #7aa2f7;">stable</span>
                  </>
                : <>
                    <span style="width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #22c55e; animation: blink 2s ease infinite;"></span>
                    <span style="font-size: 0.72rem; color: #22c55e;">live</span>
                  </>
              }
            </div>
          </div>
          <p style="font-size: 0.85rem; color: var(--muted); line-height: 1.6; margin-bottom: 1rem;">{p.description}</p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem;">
            {p.stack.map(s => <span class="tag">{s}</span>)}
          </div>
          <div style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; color: var(--accent-light);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {p.url.replace('https://', '')}
          </div>
        </a>
      ))}
    </div>

    <!-- Recent GitHub activity -->
    <h3 style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1.25rem;">최근 GitHub 활동</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
      {recent.map(p => (
        <a href={p.url} target="_blank" rel="noopener" class="card" style="text-decoration: none; display: block; cursor: pointer;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: var(--muted); flex-shrink: 0;"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              <h3 style="font-size: 0.9rem; font-weight: 600; color: var(--text);">{p.name}</h3>
            </div>
            <span style={`font-size: 0.68rem; padding: 0.15rem 0.5rem; border-radius: 9999px; border: 1px solid ${p.wip ? 'rgba(234,179,8,0.4)' : 'rgba(124,58,237,0.3)'}; color: ${p.wip ? '#eab308' : 'var(--accent-light)'}; background: ${p.wip ? 'rgba(234,179,8,0.08)' : 'var(--accent-glow)'};`}>{p.label}</span>
          </div>
          <p style="font-size: 0.82rem; color: var(--muted); line-height: 1.6; margin-bottom: 0.75rem;">{p.description}</p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
            {p.stack.map(s => <span class="tag" style="font-size: 0.7rem;">{s}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
