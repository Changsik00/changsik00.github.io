---
---

<section style="
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rem 1.5rem 4rem;
  position: relative;
  overflow: hidden;
">
  <!-- Background gradient -->
  <div style="
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% -5%, rgba(187,154,247,0.14) 0%, transparent 65%),
      radial-gradient(ellipse 40% 30% at 80% 60%, rgba(122,162,247,0.06) 0%, transparent 60%);
    pointer-events: none;
  "></div>

  <div style="max-width: 760px; width: 100%; position: relative;">
    <!-- Name -->
    <h1 class="animate-fadeInUp animate-delay-200" style="
      font-size: clamp(2.5rem, 7vw, 4.5rem);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    ">
      Changsik Jang
      <span style="display: block; color: var(--muted); font-size: 0.55em; font-weight: 400; margin-top: 0.3rem;">장창식</span>
    </h1>

    <!-- Title -->
    <h2 class="animate-fadeInUp animate-delay-300" style="
      font-size: clamp(1rem, 3vw, 1.4rem);
      font-weight: 500;
      color: var(--accent-light);
      margin-bottom: 1.5rem;
    ">
      Product-oriented Fullstack Engineer
    </h2>

    <!-- Description -->
    <p class="animate-fadeInUp animate-delay-400" style="
      font-size: 1rem;
      color: var(--muted);
      line-height: 1.75;
      max-width: 560px;
      margin-bottom: 2rem;
    ">
      Android 초기 시장(2009)부터 시작해 Web Frontend, Backend를 거쳐
      현재 AI Workflow 시대까지&mdash;제품 전체를 이해하고 끝까지 만들어내는 엔지니어입니다.
    </p>

    <!-- Stats badges -->
    <div class="animate-fadeInUp animate-delay-400" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2.5rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.9rem; background: var(--surface); border: 1px solid var(--border); border-radius: 9999px; font-size: 0.82rem; color: var(--muted);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-light)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        경력 15년+
      </div>
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.9rem; background: var(--surface); border: 1px solid var(--border); border-radius: 9999px; font-size: 0.82rem; color: var(--muted);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-light)" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        Android → Web → AI
      </div>
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.9rem; background: var(--surface); border: 1px solid var(--border); border-radius: 9999px; font-size: 0.82rem; color: var(--muted);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-light)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        서비스 기획부터 운영까지
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="animate-fadeInUp animate-delay-500" style="display: flex; flex-wrap: wrap; gap: 1rem;">
      <a href="#projects" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        프로젝트 보기
      </a>
      <a href="https://github.com/Changsik00" target="_blank" rel="noopener" class="btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        GitHub
      </a>
      <a href="mailto:lowmans00@gmail.com" class="btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    animation: fadeInUp 1s ease 1.2s forwards;
    opacity: 0;
  ">
    <span style="font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;">scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation: blink 2s ease infinite;"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>
